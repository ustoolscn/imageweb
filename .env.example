# Image Web 配置模板
# 复制为 .env 后修改；.env 不要提交到仓库。

# 后端 HTTP 监听端口。
# Docker Compose 默认把宿主机同端口映射到容器 8080；如果改成 9000，访问地址就是 http://localhost:9000。
PORT=8080

# PostgreSQL 连接串，当前项目只支持 PostgreSQL。
# 使用远程数据库部署时必填；Docker 容器内的 localhost 指的是容器自己，不是宿主机。
# 如果使用内置 PostgreSQL，请用 docker-compose.postgres.yml 叠加部署，它会覆盖这个值。
# 远程数据库示例：postgres://user:password@host:5432/image_web?sslmode=require
# 本机直接 go run 示例：postgres://user:password@localhost:5432/image_web?sslmode=disable
DATABASE_DSN=postgres://user:password@host:5432/image_web?sslmode=require

# 图床适配器。
# 可选值：
# - http-json：使用通用 HTTP multipart 上传接口，并从返回 JSON 里读取图片 URL。
# - local：保存到本地目录并返回公开访问 URL，需要额外配置 IMAGE_HOST_LOCAL_DIR 和 IMAGE_HOST_PUBLIC_BASE_URL。
IMAGE_HOST_PROVIDER=http-json

# HTTP 图床上传地址。
# IMAGE_HOST_PROVIDER=http-json 时必填；local 模式不使用。
IMAGE_HOST_UPLOAD_URL=https://2bad.lujilujilujilujiluji.com/

# HTTP 图床鉴权 header 名。
# 例如 Authorization、X-API-Key；如果图床不需要鉴权，留空。
IMAGE_HOST_AUTH_HEADER=Authorization

# HTTP 图床鉴权 header 值。
# 例如 Bearer xxx、sk-xxx；如果图床不需要鉴权，留空。
IMAGE_HOST_AUTH_VALUE=Bearer cooper

# multipart 上传时的文件字段名。
# 常见值是 file；如果你的图床要求 image、upload 等字段名，在这里改。
IMAGE_HOST_FIELD_NAME=file

# 从图床返回 JSON 中读取图片 URL 的路径。
# 支持点号路径，例如 url、data.url、result.image_url。
IMAGE_HOST_RESPONSE_URL_PATH=url

# 后端上传图片后会自动生成最长边约 480px 的缩略图，并通过同一图床保存。
# 前端列表、广场和参考图缩略区域会优先加载 thumbnail_url；大图预览和生成复用仍使用原图 URL。

# 本地图床示例。
# 只有 IMAGE_HOST_PROVIDER=local 时才需要下面两项。
# IMAGE_HOST_LOCAL_DIR：图片保存到服务器/容器内的哪个目录。
# IMAGE_HOST_PUBLIC_BASE_URL：这个目录对应的公网访问前缀，必须能被浏览器直接访问。
# IMAGE_HOST_PROVIDER=local
# IMAGE_HOST_LOCAL_DIR=/app/uploads
# IMAGE_HOST_PUBLIC_BASE_URL=https://your-domain.com/uploads/
